# Copia este archivo como .streamlit/secrets.toml y rellena tus credenciales.
# NO subas secrets.toml a Git.

# Opción 1: URL completa (recomendado para Supabase)
DATABASE_URL = "postgresql+psycopg2://postgres:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Opción 2: variables separadas (descomenta si prefieres este formato)
# [database]
# host     = "aws-0-us-east-1.pooler.supabase.com"
# port     = 6543
# name     = "postgres"
# user     = "postgres"
# password = "<password>"
