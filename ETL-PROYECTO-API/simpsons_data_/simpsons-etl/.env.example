# Local PostgreSQL / Docker
# Descomenta y ajusta según tu entorno local.
DATABASE_URL=postgresql+psycopg2://postgres:1234@localhost:5432/Simpsons_db

# Supabase pooler (reemplaza con tu credencial real)
# DATABASE_URL=postgresql+psycopg2://postgres:<your-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Alternativa: construir DATABASE_URL desde variables separadas
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=<your-password>

# Simpsons API
BASE_URL=https://thesimpsonsapi.com/api
